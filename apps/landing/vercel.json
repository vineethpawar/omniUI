{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": false,
  "trailingSlash": true,
  "rewrites": [
    {
      "source": "/docs/(.*)",
      "destination": "https://plyxui-docs.vercel.app/docs/$1"
    },
    {
      "source": "/docs",
      "destination": "https://plyxui-docs.vercel.app/docs/"
    }
  ]
}
