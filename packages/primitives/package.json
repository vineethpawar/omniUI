{
  "name": "@omniui/primitives",
  "version": "0.0.0",
  "description": "Base components. Box is the first one. Polymorphic on web, View-backed on native.",
  "license": "MIT",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "react-native": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./box": {
      "react-native": "./src/box/index.native.tsx",
      "types": "./src/box/index.tsx",
      "import": "./src/box/index.tsx"
    },
    "./text": {
      "react-native": "./src/text/index.native.tsx",
      "types": "./src/text/index.tsx",
      "import": "./src/text/index.tsx"
    },
    "./stack": {
      "react-native": "./src/stack/index.native.tsx",
      "types": "./src/stack/index.tsx",
      "import": "./src/stack/index.tsx"
    },
    "./flex": {
      "react-native": "./src/flex/index.native.tsx",
      "types": "./src/flex/index.tsx",
      "import": "./src/flex/index.tsx"
    },
    "./input": {
      "react-native": "./src/input/index.native.tsx",
      "types": "./src/input/index.tsx",
      "import": "./src/input/index.tsx"
    },
    "./button": {
      "react-native": "./src/button/index.native.tsx",
      "types": "./src/button/index.tsx",
      "import": "./src/button/index.tsx"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "lint": "echo 'todo: wire eslint'",
    "build": "echo 'todo: wire tsup or tsc emit'",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@omniui/core": "*",
    "@omniui/theme": "*",
    "class-variance-authority": "^0.7.1"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
