{
  "name": "@plyxui/styles",
  "version": "0.2.0",
  "description": "ThemeProvider and useTheme hook. Web variant uses CSS vars + localStorage. Native variant uses Appearance API.",
  "license": "MIT",
  "main": "src/index.tsx",
  "types": "src/index.tsx",
  "react-native": "src/index.native.tsx",
  "exports": {
    ".": {
      "react-native": "./src/index.native.tsx",
      "types": "./src/index.tsx",
      "import": "./src/index.tsx"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "lint": "echo 'todo: wire eslint'",
    "build": "echo 'todo: wire tsup or tsc emit'",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@plyxui/core": "*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
