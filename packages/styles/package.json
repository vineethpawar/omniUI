{
  "name": "@plyxui/styles",
  "version": "0.3.0",
  "description": "ThemeProvider and useTheme hook. Web variant uses CSS vars + localStorage. Native variant uses Appearance API.",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "react-native": "src/index.native.tsx",
  "exports": {
    ".": {
      "react-native": {
        "types": "./dist/index.native.d.ts",
        "import": "./dist/index.native.js",
        "require": "./dist/index.native.cjs",
        "default": "./dist/index.native.js"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "lint": "echo 'todo: wire eslint'",
    "build": "tsup",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@plyxui/core": "*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsup": "^8.5.1"
  },
  "type": "module",
  "module": "./dist/index.js",
  "sideEffects": false
}
