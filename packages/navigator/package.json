{
  "name": "@plyxui/navigator",
  "version": "0.1.0",
  "description": "Router-agnostic helper. defineRoutes() once; render with the right adapter on web or native.",
  "license": "MIT",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "react-native": "src/index.ts",
  "exports": {
    ".": {
      "react-native": "./src/index.native.ts",
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./react-router": {
      "types": "./src/adapters/react-router.tsx",
      "import": "./src/adapters/react-router.tsx"
    },
    "./react-navigation": {
      "types": "./src/adapters/react-navigation.tsx",
      "import": "./src/adapters/react-navigation.tsx"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "lint": "echo 'todo: wire eslint'",
    "build": "echo 'todo: wire tsup or tsc emit'",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@plyxui/core": "*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-router-dom": ">=6",
    "@react-navigation/native": ">=7"
  },
  "peerDependenciesMeta": {
    "react-router-dom": { "optional": true },
    "@react-navigation/native": { "optional": true }
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
