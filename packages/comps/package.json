{
  "name": "@plyxui/comps",
  "version": "0.3.0",
  "description": "Composite components built on the primitives: Modal, Dropdown, Tooltip, Tabs, Toast, Drawer.",
  "license": "MIT",
  "main": "./dist/index.cjs",
