        "default": "./dist/index.native.js"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./Modal": {
      "react-native": {
        "types": "./dist/Modal.native.d.ts",
        "import": "./dist/Modal.native.js",
