      },
      "types": "./dist/Modal.d.ts",
      "import": "./dist/Modal.js",
      "require": "./dist/Modal.cjs",
      "default": "./dist/Modal.js"
    },
    "./Dropdown": {
      "react-native": {
        "types": "./dist/Dropdown.native.d.ts",
