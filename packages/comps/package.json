        "require": "./dist/Drawer.native.cjs",
        "default": "./dist/Drawer.native.js"
      },
      "types": "./dist/Drawer.d.ts",
      "import": "./dist/Drawer.js",
      "require": "./dist/Drawer.cjs",
      "default": "./dist/Drawer.js"
