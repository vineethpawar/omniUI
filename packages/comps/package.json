      "require": "./dist/Dropdown.cjs",
      "default": "./dist/Dropdown.js"
    },
    "./Tooltip": {
      "react-native": {
        "types": "./dist/Tooltip.native.d.ts",
        "import": "./dist/Tooltip.native.js",
        "require": "./dist/Tooltip.native.cjs",
        "default": "./dist/Tooltip.native.js"
      },
      "types": "./dist/Tooltip.d.ts",
      "import": "./dist/Tooltip.js",
      "require": "./dist/Tooltip.cjs",
      "default": "./dist/Tooltip.js"
    },
    "./Tabs": {
      "react-native": {
        "types": "./dist/Tabs.native.d.ts",
        "import": "./dist/Tabs.native.js",
        "require": "./dist/Tabs.native.cjs",
        "default": "./dist/Tabs.native.js"
      },
      "types": "./dist/Tabs.d.ts",
      "import": "./dist/Tabs.js",
      "require": "./dist/Tabs.cjs",
