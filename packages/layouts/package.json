{
  "name": "@plyxui/layouts",
  "version": "0.2.1",
  "description": "Cross-platform layout primitives: AppShell, Sidebar, ScreenContainer. Compose with the navigator for full apps.",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "react-native": "src/index.ts",
  "exports": {
    ".": {
      "react-native": {
        "types": "./dist/index.native.d.ts",
        "import": "./dist/index.native.js",
        "require": "./dist/index.native.cjs",
        "default": "./dist/index.native.js"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./AppShell": {
      "react-native": {
        "types": "./dist/AppShell.native.d.ts",
        "import": "./dist/AppShell.native.js",
        "require": "./dist/AppShell.native.cjs",
        "default": "./dist/AppShell.native.js"
      },
      "types": "./dist/AppShell.d.ts",
      "import": "./dist/AppShell.js",
      "require": "./dist/AppShell.cjs",
      "default": "./dist/AppShell.js"
    },
    "./Sidebar": {
      "react-native": {
        "types": "./dist/Sidebar.native.d.ts",
        "import": "./dist/Sidebar.native.js",
        "require": "./dist/Sidebar.native.cjs",
        "default": "./dist/Sidebar.native.js"
      },
      "types": "./dist/Sidebar.d.ts",
      "import": "./dist/Sidebar.js",
      "require": "./dist/Sidebar.cjs",
      "default": "./dist/Sidebar.js"
    },
    "./ScreenContainer": {
      "react-native": {
        "types": "./dist/ScreenContainer.native.d.ts",
        "import": "./dist/ScreenContainer.native.js",
        "require": "./dist/ScreenContainer.native.cjs",
        "default": "./dist/ScreenContainer.native.js"
      },
      "types": "./dist/ScreenContainer.d.ts",
      "import": "./dist/ScreenContainer.js",
      "require": "./dist/ScreenContainer.cjs",
      "default": "./dist/ScreenContainer.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "lint": "echo 'todo: wire eslint'",
    "build": "tsup",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@plyxui/core": "*",
    "@plyxui/styles": "*",
    "@plyxui/primitives": "*",
    "@plyxui/icons": "*"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsup": "^8.5.1"
  },
  "type": "module",
  "module": "./dist/index.js",
  "sideEffects": false
}
