{
  "name": "@plyxui/hooks",
  "version": "0.3.0",
  "description": "Cross-platform React hooks. useDisclosure, useClickOutside, useMediaQuery, useToast. No DOM or RN assumptions in the public API.",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "react-native": "src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "lint": "echo 'todo: wire eslint'",
    "build": "tsup",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@plyxui/core": "*"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsup": "^8.5.1"
  },
  "type": "module",
  "module": "./dist/index.js",
  "sideEffects": false
}
