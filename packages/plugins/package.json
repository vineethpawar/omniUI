{
  "name": "@omniui/plugins",
  "version": "0.1.0",
  "description": "Heavyweight components: CommandPalette, DataTable (planned), Chart (planned). Opt-in; the rest of omniUI doesn't pull these in.",
  "license": "MIT",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "react-native": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./command-palette": {
      "types": "./src/CommandPalette/index.tsx",
      "import": "./src/CommandPalette/index.tsx"
    }
  },
  "files": ["src"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "check-types": "tsc --noEmit",
    "lint": "echo 'todo: wire eslint'",
    "build": "echo 'todo: wire tsup'",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@omniui/core": "*",
    "@omniui/styles": "*",
    "@omniui/primitives": "*",
    "@omniui/icons": "*",
    "@omniui/comps": "*",
    "@omniui/hooks": "*"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
