{
  "name": "@plyxui/plugins",
  "version": "0.2.1",
  "description": "Heavyweight components: CommandPalette, DataTable (planned), Chart (planned). Opt-in; the rest of plyxui doesn't pull these in.",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "react-native": "src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./CommandPalette": {
      "types": "./dist/CommandPalette.d.ts",
      "import": "./dist/CommandPalette.js",
      "require": "./dist/CommandPalette.cjs",
      "default": "./dist/CommandPalette.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "lint": "echo 'todo: wire eslint'",
    "build": "tsup",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@plyxui/core": "*",
    "@plyxui/styles": "*",
    "@plyxui/primitives": "*",
    "@plyxui/icons": "*",
    "@plyxui/comps": "*",
    "@plyxui/hooks": "*"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsup": "^8.5.1"
  },
  "type": "module",
  "module": "./dist/index.js",
  "sideEffects": false
}
