{
  "name": "@plyxui/core",
  "version": "0.2.0",
  "description": "Design tokens, polymorphic types, and headless hooks. Pure TS, no DOM, no RN.",
  "license": "MIT",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./tokens": {
      "react-native": "./src/tokens/index.ts",
      "types": "./src/tokens/index.ts",
      "import": "./src/tokens/index.ts",
      "default": "./src/tokens/index.ts"
    },
    "./types": {
      "react-native": "./src/types/index.ts",
      "types": "./src/types/index.ts",
      "import": "./src/types/index.ts",
      "default": "./src/types/index.ts"
    },
    "./hooks": {
      "react-native": "./src/hooks/index.ts",
      "types": "./src/hooks/index.ts",
      "import": "./src/hooks/index.ts",
      "default": "./src/hooks/index.ts"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "lint": "echo 'todo: wire eslint'",
    "build": "echo 'todo: wire tsup or tsc emit'",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
